package Day01;

class Human
{
	private int age=20;
	private String name="Naveen";
	
	public int getAge()
	{
		return age;
	}

	public String getName()
	{
		return name;
	}


}

public class EncapsulationDemo
{

	public static void main(String[] args)
	{
		Human h = new Human();
		//h.age=28;
	//	h.name="Naveen";
		System.out.println(h.getAge());
		System.out.println(h.getName());
		
	}

}
